{
  "name": "skill-admin",
  "version": "0.1.0",
  "description": "Local web UI to browse, edit, create and delete Claude Code skills & commands",
  "type": "module",
  "license": "MIT",
  "bin": { "skill-admin": "dist/server.js" },
  "scripts": {
    "dev:server": "tsx watch src/server/server.ts",
    "dev:web": "vite",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "build:web": "vite build",
    "build:server": "node scripts/build-server.mjs",
    "build": "npm run build:web && npm run build:server",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": { "yaml": "^2.5.0" },
  "devDependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
